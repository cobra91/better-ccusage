{
	"name": "@better-ccusage/mcp",
	"version": "1.3.1",
	"description": "MCP server implementation for better-ccusage data with multi-provider support",
	"homepage": "https://github.com/cobra91/better-ccusage#readme",
	"bugs": {
		"url": "https://github.com/cobra91/better-ccusage/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cobra91/better-ccusage.git"
	},
	"funding": "https://github.com/cobra91/better-ccusage?sponsor=1",
	"license": "MIT",
	"author": "cobra91",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"better-ccusage-mcp": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "bun -b --watch ./src/index.ts",
		"format": "pnpm run lint --fix",
		"lint": "eslint --cache .",
		"prepack": "pnpm run build && clean-pkg-json",
		"prerelease": "pnpm run lint && pnpm run typecheck && pnpm run build",
		"start": "bun ./src/index.ts",
		"test": "TZ=UTC vitest",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@better-ccusage/codex": "workspace:*",
		"@better-ccusage/internal": "workspace:*",
		"@better-ccusage/terminal": "workspace:*",
		"@hono/mcp": "catalog:runtime",
		"@hono/node-server": "catalog:runtime",
		"@modelcontextprotocol/sdk": "catalog:runtime",
		"@praha/byethrow": "catalog:runtime",
		"@ryoppippi/eslint-config": "catalog:lint",
		"@typescript/native-preview": "catalog:types",
		"better-ccusage": "workspace:*",
		"clean-pkg-json": "catalog:release",
		"eslint": "catalog:lint",
		"fs-fixture": "catalog:testing",
		"gunshi": "catalog:runtime",
		"hono": "catalog:runtime",
		"nano-spawn": "catalog:runtime",
		"publint": "catalog:lint",
		"tsdown": "catalog:build",
		"valibot": "catalog:runtime",
		"vitest": "catalog:testing",
		"zod": "catalog:runtime"
	},
	"engines": {
		"node": ">=20.19.4"
	},
	"publishConfig": {
		"bin": {
			"better-ccusage-mcp": "./dist/index.js"
		},
		"exports": {
			".": "./dist/index.js",
			"./package.json": "./package.json"
		}
	}
}
