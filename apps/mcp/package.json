{
	"name": "@better-ccusage/mcp",
	"version": "1.3.2",
	"description": "MCP server implementation for better-ccusage data with multi-provider support",
	"homepage": "https://github.com/cobra91/better-ccusage#readme",
	"bugs": {
		"url": "https://github.com/cobra91/better-ccusage/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cobra91/better-ccusage.git"
	},
	"funding": "https://github.com/cobra91/better-ccusage?sponsor=1",
	"license": "MIT",
	"author": "cobra91",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"better-ccusage-mcp": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pnpm tsdown && node -e \"require('fs').copyFileSync('../../packages/internal/model_prices_and_context_window.json','dist/model_prices_and_context_window.json')\"",
		"prepack": "pnpm run build && pnpm clean-pkg-json"
	},
	"engines": {
		"node": ">=20.19.4"
	},
	"publishConfig": {
		"bin": {
			"better-ccusage-mcp": "./dist/index.js"
		},
		"exports": {
			".": "./dist/index.js",
			"./package.json": "./package.json"
		}
	}
}
